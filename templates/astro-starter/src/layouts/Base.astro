---
// Base.astro — document shell. Loads tokens + globals, preloads the two
// latin-subset variable woff2 files, sets meta / color-scheme / theme-color,
// and applies the stored color scheme before paint (no flash of wrong theme).
import "../styles/tokens.css"; // tokens FIRST (source of truth)
import "../styles/global.css"; // then fonts + resets

// Astro's SPA-style client-side router. Enables native CSS View Transitions:
// same-origin navigations cross-fade instead of doing a hard reload, and any
// element with a shared `view-transition-name` (see the hero <h1>) MORPHS
// across pages. Pure progressive enhancement — without JS / in browsers that
// lack the View Transitions API, navigation falls back to a normal full load.
import { ClientRouter } from "astro:transitions";

// Self-hosted woff2 paths (Fontsource ships these under the package's /files).
// Vite resolves the bare specifier; preloading the latin range kills FOUT.
import bricolageWoff2 from "@fontsource-variable/bricolage-grotesque/files/bricolage-grotesque-latin-wght-normal.woff2?url";
import hankenWoff2 from "@fontsource-variable/hanken-grotesk/files/hanken-grotesk-latin-wght-normal.woff2?url";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "cila starter",
  description = "A cila-generated marketing site. Edit DESIGN.md + src/styles/tokens.css.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Light + dark theme colors (the address bar tints to match scheme). -->
    <meta
      name="theme-color"
      content="#fbfdfb"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#0f1411"
      media="(prefers-color-scheme: dark)"
    />

    <!-- Preload the two display/body variable faces (latin subset). -->
    <link
      rel="preload"
      href={bricolageWoff2}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={hankenWoff2}
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Open Graph / social (fill these in per site). -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />

    <!-- View Transitions: cross-fade + shared-element morph on same-origin
         nav. Degrades to a normal full reload where unsupported. -->
    <ClientRouter />

    <!-- Speculation Rules: ask the browser to prerender same-origin nav
         targets just before the user commits to them, so the next page is
         already warm. `moderate` eagerness = on hover / pointerdown (not
         eagerly on load), which keeps it cheap and respectful of data.
         The demo is a single page, so nothing matches yet — the rule is
         included as the pattern to keep once real routes exist. It's a
         progressive enhancement: unsupported browsers ignore the script,
         and the `href_matches` "/*" scope is same-origin-only by spec. -->
    <script type="speculationrules">
      {
        "prerender": [
          {
            "source": "document",
            "where": {
              "and": [
                { "href_matches": "/*" },
                { "not": { "href_matches": "/*\\?*" } },
                { "not": { "selector_matches": "[rel~=nofollow]" } },
                { "not": { "selector_matches": "[data-no-prerender]" } }
              ]
            },
            "eagerness": "moderate"
          }
        ]
      }
    </script>

    <!-- No-flash color scheme: honor a saved choice, else system. Runs pre-paint. -->
    <script is:inline>
      (() => {
        const saved = localStorage.getItem("theme");
        const dark =
          saved === "dark" ||
          (!saved && matchMedia("(prefers-color-scheme: dark)").matches);
        document.documentElement.classList.toggle("dark", dark);
      })();
    </script>
  </head>

  <body>
    <slot />
  </body>
</html>
