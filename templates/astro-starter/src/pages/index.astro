---
// index.astro — a REAL sample landing page that exercises the token system.
// Everything here uses semantic tokens (bg-bg, text-fg, bg-brand, …) — no raw
// hex, no Tailwind color literals. Re-hue the whole page from tokens.css.
//
// Design intent (deliberately NOT default-shadcn):
//   • Asymmetric hero: oversized display headline on a 12-col grid that breaks
//     to the left, with an offset, overlapping "specimen" card on the right.
//   • One orchestrated page-load motion: staggered reveal, CSS-only, guarded by
//     prefers-reduced-motion (see <style> at the bottom).
//   • Type tension: Bricolage Grotesque display vs. Hanken Grotesk body.
//   • A mesh-ish brand glow built from layered radial-gradients (no image).
import Base from "../layouts/Base.astro";

const features = [
  {
    kicker: "01",
    title: "One hue, whole system",
    body: "Every accent, ring, shadow and gradient derives from a single OKLCH --brand-hue. Swap one number, re-skin the site — contrast stays intact.",
  },
  {
    kicker: "02",
    title: "Tailwind v4, CSS-first",
    body: "Tokens live in @theme — no tailwind.config.js. The stylesheet is the design contract, so generators and gates read the same source of truth.",
  },
  {
    kicker: "03",
    title: "Fonts you own",
    body: "Bricolage Grotesque + Hanken Grotesk, self-hosted via Fontsource and preloaded. No Google CDN, no FOUT, no Inter.",
  },
];
---

<Base title="cila — design that doesn't drift to the mean">
  <!-- skip link for keyboard users -->
  <a
    href="#main"
    class="sr-only focus-visible:not-sr-only focus-visible:fixed focus-visible:left-4 focus-visible:top-4 focus-visible:z-50 focus-visible:rounded-md focus-visible:bg-surface-raised focus-visible:px-4 focus-visible:py-2 focus-visible:text-fg focus-visible:shadow-md"
  >
    Skip to content
  </a>

  <!-- ── Header ─────────────────────────────────────────────────────────── -->
  <header
    class="mx-auto flex max-w-6xl items-center justify-between px-6 py-6 md:px-10"
  >
    <a href="/" class="flex items-center gap-2 font-display text-lg font-semibold tracking-tight">
      <span
        class="inline-block size-3 rounded-full bg-brand"
        aria-hidden="true"></span>
      cila
    </a>
    <nav class="flex items-center gap-6 text-sm text-fg-muted">
      <!-- py-2/-my-2: ≥24px hit target (WCAG 2.5.8) without shifting the row. -->
      <a
        href="#features"
        class="-my-2 inline-flex items-center py-2 transition-colors hover:text-fg"
        >Features</a
      >
      <a
        href="#"
        class="hidden rounded-full border border-border-strong px-4 py-1.5 font-medium text-fg transition-colors hover:border-brand hover:text-brand sm:inline-block"
        >Docs</a
      >
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle color scheme"
        class="grid size-9 place-items-center rounded-full border border-border text-fg-muted transition-colors hover:border-brand hover:text-brand"
      >
        <svg
          class="size-4 dark:hidden"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
          ><circle cx="12" cy="12" r="4"></circle><path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
          ></path></svg
        >
        <svg
          class="hidden size-4 dark:block"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
          ><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg
        >
      </button>
    </nav>
  </header>

  <main id="main">
    <!-- ── Hero (asymmetric 12-col) ───────────────────────────────────────── -->
    <section class="relative overflow-hidden">
      <!-- layered brand glow — pure CSS radial-gradient mesh, no image -->
      <div
        class="pointer-events-none absolute inset-0 -z-10"
        style="background:
          radial-gradient(60% 50% at 15% 0%, var(--color-brand-soft) 0%, transparent 60%),
          radial-gradient(50% 40% at 95% 20%, var(--color-accent-soft) 0%, transparent 55%);"
        aria-hidden="true">
      </div>

      <div
        class="reveal mx-auto grid max-w-6xl grid-cols-1 gap-y-12 px-6 pb-24 pt-12 md:grid-cols-12 md:gap-x-8 md:px-10 md:pt-20"
      >
        <!-- headline column — intentionally wider + left-weighted -->
        <div class="md:col-span-7 lg:col-span-7">
          <p
            class="reveal-item mb-6 inline-flex items-center gap-2 rounded-full border border-border bg-surface-raised px-3 py-1 text-sm font-medium text-fg-muted"
          >
            <span class="size-1.5 rounded-full bg-accent" aria-hidden="true"
            ></span>
            cila starter · Astro + Tailwind v4
          </p>
          <h1
            class="hero-title reveal-item text-5xl font-semibold leading-[0.95] tracking-tight text-fg sm:text-6xl lg:text-7xl"
          >
            Design that doesn't
            <span class="text-brand"> drift</span> to the mean.
          </h1>
          <p
            class="reveal-item mt-6 max-w-prose text-lg text-fg-muted md:text-xl"
          >
            A real, minimal-but-complete starter wired to one OKLCH brand hue, a
            CSS-first token system, and self-hosted variable type. Edit
            <code
              class="rounded bg-surface px-1.5 py-0.5 font-mono text-sm text-fg"
              >tokens.css</code
            >, re-skin everything.
          </p>
          <div class="reveal-item mt-9 flex flex-wrap items-center gap-4">
            <a
              href="#features"
              class="group inline-flex items-center gap-2 rounded-full bg-brand px-6 py-3 font-medium text-fg-on-brand shadow-md transition-[background-color,transform] hover:bg-brand-hover active:translate-y-px"
            >
              See the system
              <span
                class="transition-transform group-hover:translate-x-0.5"
                aria-hidden="true">→</span
              >
            </a>
            <a
              href="#"
              class="inline-flex items-center gap-2 rounded-full px-2 py-3 font-medium text-fg-muted underline-offset-4 transition-colors hover:text-fg hover:underline"
            >
              Read the design contract
            </a>
          </div>
        </div>

        <!-- type-specimen card — offset down + overlapping the grid gutter -->
        <div
          class="reveal-item md:col-span-5 md:mt-16 lg:-ml-6 lg:mt-24"
        >
          <figure
            class="rotate-1 rounded-2xl border border-border bg-surface-raised p-7 shadow-lg transition-transform hover:rotate-0"
          >
            <figcaption
              class="mb-4 flex items-baseline justify-between text-xs uppercase tracking-widest text-fg-subtle"
            >
              <span>Display / Body</span><span>OKLCH</span>
            </figcaption>
            <p class="font-display text-6xl font-semibold leading-none text-fg">
              Aa
            </p>
            <p class="mt-2 font-display text-sm text-fg-muted">
              Bricolage Grotesque
            </p>
            <hr class="my-5 border-border" />
            <p class="font-body text-2xl leading-tight text-fg">
              The quick brown fox.
            </p>
            <p class="mt-2 text-sm text-fg-muted">Hanken Grotesk · 100–900</p>
            <div class="mt-6 flex gap-2" aria-hidden="true">
              <span class="h-8 flex-1 rounded-md bg-brand-strong"></span>
              <span class="h-8 flex-1 rounded-md bg-brand"></span>
              <span class="h-8 flex-1 rounded-md bg-brand-soft"></span>
              <span class="h-8 flex-1 rounded-md bg-accent"></span>
            </div>
          </figure>
        </div>
      </div>
    </section>

    <!-- ── Features (offset, not a centered 3-box grid) ───────────────────── -->
    <section
      id="features"
      class="mx-auto max-w-6xl scroll-mt-12 px-6 py-20 md:px-10"
    >
      <div class="mb-14 max-w-2xl">
        <p class="mb-3 font-mono text-sm text-brand">// the rig</p>
        <h2 class="text-4xl font-semibold tracking-tight text-fg md:text-5xl">
          Tokens first. Everything else follows.
        </h2>
      </div>

      <ul class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-border bg-border md:grid-cols-3">
        {
          features.map((f) => (
            <li class="group flex flex-col gap-4 bg-surface-raised p-8 transition-colors hover:bg-surface">
              <span class="font-mono text-sm text-fg-subtle transition-colors group-hover:text-brand">
                {f.kicker}
              </span>
              <h3 class="font-display text-2xl font-semibold leading-tight text-fg">
                {f.title}
              </h3>
              <p class="text-fg-muted">{f.body}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- ── CTA band ───────────────────────────────────────────────────────── -->
    <section class="mx-auto max-w-6xl px-6 pb-24 md:px-10">
      <div
        class="relative overflow-hidden rounded-2xl border border-border-strong bg-brand-strong px-8 py-14 text-center md:py-20"
      >
        <div
          class="pointer-events-none absolute inset-0 opacity-40"
          style="background: radial-gradient(60% 120% at 50% 0%, var(--color-brand) 0%, transparent 70%);"
          aria-hidden="true">
        </div>
        <h2
          class="relative text-3xl font-semibold tracking-tight text-fg-on-brand md:text-4xl"
        >
          Point an agent at it.
        </h2>
        <p class="relative mx-auto mt-4 max-w-md text-fg-on-brand/80">
          Run <code class="font-mono">/cila:go</code>, lock a DESIGN.md, and let
          the build loop ship from this contract.
        </p>
      </div>
    </section>
  </main>

  <!-- ── Footer ─────────────────────────────────────────────────────────── -->
  <footer class="border-t border-border">
    <div
      class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-4 px-6 py-10 text-sm text-fg-muted sm:flex-row sm:items-center md:px-10"
    >
      <p class="flex items-center gap-2">
        <span class="inline-block size-2 rounded-full bg-brand" aria-hidden="true"
        ></span>
        Generated with cila · edit
        <code class="font-mono text-fg">DESIGN.md</code>
      </p>
      <p>© {new Date().getFullYear()} — replace this.</p>
    </div>
  </footer>

  <script>
    // theme toggle (persists; the no-flash script in Base.astro reads it)
    const btn = document.getElementById("theme-toggle");
    btn?.addEventListener("click", () => {
      const isDark = document.documentElement.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });
  </script>
</Base>

<style>
  /* ── View Transitions ─────────────────────────────────────────────────────
     Opt the document into the native cross-document/SPA transition. With
     <ClientRouter /> (Base.astro) this cross-fades same-origin navigations;
     `auto` lets the UA pick the default animation. No-op where unsupported. */
  @view-transition {
    navigation: auto;
  }

  /* Give the hero headline a named transition so it MORPHS (rather than
     cross-fades) when it persists across a navigation — e.g. shrinking into a
     header title on the next page. The name must be unique per page.
     Guarded by reduced-motion: we drop the name so the element just swaps. */
  @media (prefers-reduced-motion: no-preference) {
    .hero-title {
      view-transition-name: hero-title;
    }
  }

  /* ── Reveal: native CSS scroll-driven animation (animation-timeline: view()).
     Each `.reveal-item` fades + rises as it enters the scrollport, driven by
     the browser on the compositor — NO JS, NO IntersectionObserver. Items
     already in view at load (the hero) resolve straight to their rest state.

     Progressive enhancement (matches templates/wow/css/ScrollReveal):
       • Wrapped in @supports (animation-timeline: view()) — browsers without
         scroll-driven animations render every item visible at rest (the base
         rule below), never hidden-and-stuck.
       • prefers-reduced-motion: no-preference gate inside, plus a hard
         reduced-motion freeze after, so motion-averse users see content at rest.
     transform/opacity only → compositor-friendly, CLS-safe. */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .reveal-item {
        opacity: 0;
        transform: translateY(12px);
        animation: reveal-up linear forwards;
        animation-timeline: view();
        /* play from "entering the scrollport" to "30% covered", then hold */
        animation-range: entry 0% cover 30%;
      }

      /* Stagger via per-item range offsets (pure CSS, no setTimeout). */
      .reveal-item:nth-child(2) {
        animation-range: entry 6% cover 36%;
      }
      .reveal-item:nth-child(3) {
        animation-range: entry 12% cover 42%;
      }
      .reveal-item:nth-child(4) {
        animation-range: entry 18% cover 48%;
      }

      /* The specimen card is in a sibling column; give it a later beat. */
      .reveal > div:last-child .reveal-item {
        animation-range: entry 24% cover 54%;
      }
    }
  }

  @keyframes reveal-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Hard reduced-motion freeze (also overrides the @supports path above). */
  @media (prefers-reduced-motion: reduce) {
    .reveal-item {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
