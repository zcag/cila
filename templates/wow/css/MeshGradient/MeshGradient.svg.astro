---
/* ============================================================================
   MeshGradient.svg.astro — Tier 1 variant using SVG feTurbulence +
   feDisplacementMap to warp a token-coloured gradient into an organic,
   liquid mesh. Heavier than the layered-radial version (SVG filters paint on
   the CPU/GPU each frame), so prefer the plain `MeshGradient.astro` for hero
   backgrounds and reach for this only when you want a distinctly "liquid",
   warped look and the surface is small/static-ish.

   Animation: we animate the feTurbulence `baseFrequency` via SMIL <animate>,
   which most engines composite; we DO NOT animate the gradient itself. Under
   prefers-reduced-motion the <animate> is removed and a single warped frame
   remains. Colours via tokens only.

   NOTE on SMIL: <animate> is widely supported for filter primitives but is not
   tweenable to the compositor the way `transform` is — keep the displaced area
   modest and test the Lighthouse "non-composited animations" audit. If it fails
   your perf budget, use the layered-radial MeshGradient instead.
   ========================================================================== */
interface Props {
  class?: string;
  /** disable the baseFrequency animation entirely (static warped frame) */
  static?: boolean;
}
const { class: className = "", static: isStatic = false } = Astro.props;
const uid = "mesh-" + Math.random().toString(36).slice(2, 8);
---

<svg
  class:list={["cila-mesh-svg", className]}
  aria-hidden="true"
  preserveAspectRatio="xMidYMid slice"
  viewBox="0 0 100 100"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <radialGradient id={`${uid}-g`} cx="35%" cy="30%" r="80%">
      <stop offset="0%" stop-color="var(--color-brand-soft)" />
      <stop offset="45%" stop-color="var(--color-accent-soft)" />
      <stop offset="100%" stop-color="var(--color-bg)" />
    </radialGradient>

    <filter id={`${uid}-warp`} x="-20%" y="-20%" width="140%" height="140%">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.012 0.018"
        numOctaves="2"
        seed="7"
        result="noise"
      >
        {
          !isStatic && (
            <animate
              attributeName="baseFrequency"
              dur="28s"
              keyTimes="0;0.5;1"
              values="0.012 0.018;0.02 0.012;0.012 0.018"
              repeatCount="indefinite"
            />
          )
        }
      </feTurbulence>
      <feDisplacementMap
        in="SourceGraphic"
        in2="noise"
        scale="22"
        xChannelSelector="R"
        yChannelSelector="G"
      />
    </filter>
  </defs>

  <rect
    x="-20"
    y="-20"
    width="140"
    height="140"
    fill={`url(#${uid}-g)`}
    filter={`url(#${uid}-warp)`}
  />
</svg>

{
  /* Reduced-motion is the one case SMIL can't honour via CSS. This tiny inline
     script removes the <animate> at runtime if the user asked for less motion,
     leaving a single warped static frame. Runs once, no framework. */
  !isStatic && (
    <script is:inline define:vars={{ uid }}>
      if (matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document
          .getElementById(uid + "-warp")
          ?.querySelector("animate")
          ?.remove();
      }
    </script>
  )
}

<style>
  .cila-mesh-svg {
    position: absolute;
    inset: 0;
    z-index: -1;
    width: 100%;
    height: 100%;
    pointer-events: none;
    background: var(--color-bg);
  }
  /* Reduced-motion freeze is handled by the inline script above (SMIL can't be
     paused via CSS). Pass `static` to opt out of motion at author time. */
</style>
