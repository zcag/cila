---
/* ============================================================================
   Grain.astro — Tier 1 (zero-dep, SVG feTurbulence). A fine film-grain / noise
   overlay that sits on top of content to add texture and break up flat fills
   and gradient banding. The noise is a single static feTurbulence raster (data
   URI), so it costs essentially nothing — no animation by default.

   Optional `animate` prop adds a subtle grain "shimmer" by translating the
   oversized noise tile on the COMPOSITOR (transform only). Under
   prefers-reduced-motion that motion is removed (the static grain stays).

   The grain is intentionally colourless (it's luminance noise) and applied via
   opacity + mix-blend-mode so it reads against ANY token background without
   introducing a hardcoded colour. Tune density with `opacity`.
   ========================================================================== */
interface Props {
  class?: string;
  /** overlay strength, 0–1 (film grain is subtle: 0.04–0.1) */
  opacity?: number;
  /** noise frequency — higher = finer grain */
  frequency?: number;
  /** add a compositor-only shimmer (off by default) */
  animate?: boolean;
}
const {
  class: className = "",
  opacity = 0.06,
  frequency = 0.8,
  animate = false,
} = Astro.props;

/* A self-contained SVG noise tile as a data URI — no network request, no extra
   DOM. feTurbulence(fractalNoise) → desaturate-ish via low alpha at use site. */
const noise = `<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='${frequency}' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>`;
const dataUri = `url("data:image/svg+xml,${noise.replace(/#/g, "%23").replace(/"/g, "'")}")`;
---

<div
  class:list={["cila-grain", animate && "cila-grain--animate", className]}
  aria-hidden="true"
  style={`--grain-img:${dataUri}; --grain-opacity:${opacity}`}
>
</div>

<style>
  .cila-grain {
    position: absolute;
    inset: 0;
    z-index: 1; /* above background, below content if content has higher z */
    pointer-events: none;
    background-image: var(--grain-img);
    background-repeat: repeat;
    opacity: var(--grain-opacity);
    /* blend so the grain modulates the underlying colour instead of greying it.
       overlay/soft-light both work; soft-light is gentler. */
    mix-blend-mode: soft-light;
  }

  /* Optional shimmer: oversize the tile and translate it (compositor only).
     We size the layer bigger than its box so the translate never reveals edges. */
  .cila-grain--animate {
    inset: -50%;
    width: 200%;
    height: 200%;
    will-change: transform;
    animation: cila-grain-drift 1.2s steps(6) infinite;
  }

  @keyframes cila-grain-drift {
    0%   { transform: translate3d(0, 0, 0); }
    20%  { transform: translate3d(-3%, 2%, 0); }
    40%  { transform: translate3d(2%, -3%, 0); }
    60%  { transform: translate3d(-2%, -2%, 0); }
    80%  { transform: translate3d(3%, 1%, 0); }
    100% { transform: translate3d(0, 0, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cila-grain--animate {
      animation: none !important;
      will-change: auto;
      /* park it back to a full-cover static tile */
      inset: 0;
      width: 100%;
      height: 100%;
    }
  }
</style>
