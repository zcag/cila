{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f DESIGN.md && echo '[cila] This repo is cila-enabled and has a DESIGN.md design contract. Read it and treat it as the source of truth for all UI work; run `npm run gate` before shipping.' || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/stop-gate.sh\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/stop-gate.sh\""
          }
        ]
      }
    ]
  }
}
